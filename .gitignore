# Secrets — never commit (API-Football key etc.)
.env
.env.*
!.env.example

# Python virtual environment (1.6 GB — never commit)
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# macOS
.DS_Store

# Local working notes / scratch
comments/

# M3 raw API-Football cache — caching is allowed but REDISTRIBUTING raw API
# data is not (and this repo is public). Keep raw responses local only.
v2/m3/cache/
# Derived corpus tables are reshaped API-Football data (same redistribution
# concern) and are fully regenerable by re-running v2/m3/*.py. Key results
# (b_susp, CI, gate verdict) live in the committed M3_*.md docs.
v2/m3/corpus/

# NOTE: output/ is intentionally NOT ignored.
# The trained weights (output/model/), predictions.json, and the HTML report
# are part of the locked v1 baseline so future versions can be compared against
# these exact numbers. See memory/baseline-locked.md.
